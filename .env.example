# Flask Configuration
FLASK_ENV=development
FLASK_SECRET_KEY=change-this-to-a-long-random-string-in-production
FLASK_DEBUG=1

# Database Configuration
# For development (local PostgreSQL)
DATABASE_URL=postgresql://bloguser:blogpass@localhost:5432/blogdb
# For Docker Compose
# DATABASE_URL=postgresql://bloguser:blogpass@postgres:5432/blogdb

# Redis Configuration
# For development (local Redis)
REDIS_URL=redis://localhost:6379/0
# For Docker Compose
# REDIS_URL=redis://redis:6379/0

# Celery Configuration
# For development (local Redis)
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
# For Docker Compose
# CELERY_BROKER_URL=redis://redis:6379/0
# CELERY_RESULT_BACKEND=redis://redis:6379/1

# Email Configuration (SMTP)
# Gmail example (use app password, not regular password)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_DEFAULT_SENDER=your-email@gmail.com

# File Upload Configuration
MAX_CONTENT_LENGTH=10485760
UPLOAD_FOLDER=app/static/uploads
ALLOWED_EXTENSIONS=jpg,jpeg,png,gif,webp

# JWT Configuration
JWT_SECRET_KEY=another-long-random-string-for-jwt-tokens
JWT_ACCESS_TOKEN_EXPIRES=3600
JWT_REFRESH_TOKEN_EXPIRES=604800

# Rate Limiting Configuration
# For development (local Redis)
RATELIMIT_STORAGE_URI=redis://localhost:6379/2
# For Docker Compose
# RATELIMIT_STORAGE_URI=redis://redis:6379/2

# Sentry Configuration (optional, for error tracking)
# SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# PostgreSQL Configuration (for Docker Compose)
POSTGRES_DB=blogdb
POSTGRES_USER=bloguser
POSTGRES_PASSWORD=blogpass